  "paths": {
    "/posts/search": {
      "get": {
        "tags": [
          "Posts"
        ],
        "summary": "Search",
        "description": "Поиск документов по текстовому запросу.\nвозвращает первые 20 документов из PostgreSQL, упорядоченных по дате создания.\n\nArgs:\n    query: Текстовый запрос для поиска.\n    db: Асинхронная сессия PostgreSQL.\n    es: Асинхронный клиент Elasticsearch.\n\nReturns:\n    Список из максимум 20 документов со всеми полями БД\n    (id, rubrics, text, created_date).",
        "operationId": "search_posts_search_get",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Query"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true
                  },
                  "title": "Response Search Posts Search Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/posts/delete_post/{post_id}": {
      "delete": {
        "tags": [
          "Posts"
        ],
        "summary": "Delete Post",
        "description": "Удаление поста по его ID.\nУдаляет запись как из базы данных PostgreSQL, так и из индекса Elasticsearch.\n\nArgs:\n    post_id (int): Уникальный идентификатор поста для удаления.\n    db (AsyncSession, optional): Асинхронная сессия базы данных.\n        Автоматически внедряется через Depends(get_db).\n\nReturns:\n    dict: Словарь с результатом операции:\n        {\"status\": \"success\"}\n\nRaises:\n    HTTPException: Если документ с указанным ID не найден (404).",
        "operationId": "delete_post_posts_delete_post__post_id__delete",
        "parameters": [
          {
            "name": "post_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Post Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Delete Post Posts Delete Post  Post Id  Delete"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
